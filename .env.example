# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# docker-compose substitutes ${VAR} references from this file at the compose-file location.

# ──────────────────────────────────────────────
# PostgreSQL (Neon)
# ──────────────────────────────────────────────
DB_CONNECTION_STRING=Host=YOUR_NEON_HOST;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD;Ssl Mode=Require;

# ──────────────────────────────────────────────
# Gemini AI
# ──────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ──────────────────────────────────────────────
# JWT signing (must be >= 32 bytes for HS256)
# ──────────────────────────────────────────────
JWT_KEY=replace_with_a_random_32_byte_or_longer_secret
JWT_ISSUER=FinancialTwinAPI
JWT_AUDIENCE=FinancialTwinApp
